# signup-monitor configuration
# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Matrix -----------------------------------------------------------------
# Base URL of your Matrix homeserver's client API.
MATRIX_BASE_URL=https://chat.example.social
# Access token for the bot account that posts into the room.
MATRIX_ACCESS_TOKEN=syt_your_bot_access_token_here
# Internal room ID (starts with !, not a #alias) of the admins room.
MATRIX_ROOM_ID=!yourRoomId:chat.example.social

# --- Mastodon ---------------------------------------------------------------
# Base URL of your Mastodon instance (used for admin links in messages).
MASTODON_BASE_URL=https://example.social
# The secret shown when you create the webhook in Mastodon admin.
# Sent back in the Signature header; leave blank to skip verification.
MASTODON_SIGNING_SECRET=

# --- Who to ping in the room ------------------------------------------------
PING_PLAIN=@admin
PING_HTML=<a href="https://matrix.to/#/@admin:chat.example.social">@admin</a>

# --- Misc -------------------------------------------------------------------
# Log file path. Keep it OUTSIDE any web-served directory (contains no PII by
# default, but errors may include payload fragments).
LOG_FILE=/var/log/signup-monitor/signup-monitor.log
# Set true to log raw incoming payloads (contains PII: emails, IPs). Debug only.
DEBUG=false
