# signup-report-monitor configuration. Copy to .env and fill in. Never commit .env.

# --- Matrix (where messages are posted) ---
MATRIX_BASE_URL=https://chat.mementomori.social
MATRIX_ACCESS_TOKEN=syt_your_bot_token_here
MATRIX_ROOM_ID=!yourRoomId:chat.mementomori.social

# --- Mastodon (webhook source) ---
MASTODON_BASE_URL=https://mementomori.social
# Signing secret from Mastodon admin webhook settings (verifies X-Hub-Signature)
MASTODON_SIGNING_SECRET=your_webhook_signing_secret
# Admin token for emoji approve/reject/resolve. Scopes: admin:write:accounts
# (approve/reject signups) + admin:write:reports (resolve reports). No read scopes.
MASTODON_ADMIN_TOKEN=

# --- Optional mention appended to each message ---
PING_PLAIN=@rolle
PING_HTML=<a href="https://matrix.to/#/@rolle:chat.mementomori.social">@rolle</a>
# User id put in m.mentions so the ping actually notifies/highlights. If left
# blank it is derived from the matrix.to link in PING_HTML.
PING_USER_ID=@rolle:chat.mementomori.social

# --- HTTP listener (bound to localhost, put behind nginx) ---
LISTEN_ADDR=127.0.0.1
LISTEN_PORT=8099
WEBHOOK_PATH=/hooks/mastodon

# --- GeoIP enrichment (offline MaxMind mmdb; leave empty to disable) ---
GEOIP_CITY_DB=/home/rolle/signup-report-monitor/geoip/GeoLite2-City.mmdb
GEOIP_ASN_DB=/home/rolle/signup-report-monitor/geoip/GeoLite2-ASN.mmdb

# --- Claude analyser (bot/spam verdict). Runs as the daemon user. ---
# Runs asynchronously: the message posts instantly, the verdict is edited in.
CLAUDE_ENABLED=false
CLAUDE_BIN=claude
# Model alias for the latest, smartest model.
CLAUDE_MODEL=opus
# Allow read-only web lookups (email/IP/domain reputation) during analysis.
CLAUDE_WEB=true
CLAUDE_TIMEOUT=240

# --- Emoji approve/reject worker (2C). Needs MASTODON_ADMIN_TOKEN. ---
REACTIONS_ENABLED=false
STATE_DIR=/home/rolle/signup-report-monitor/state

# --- Logging (keep LOG_FILE outside any web-served directory) ---
LOG_FILE=/var/log/signup-report-monitor/signup-report-monitor.log
# DEBUG=true logs message bodies (PII). Only set transiently.
DEBUG=false
